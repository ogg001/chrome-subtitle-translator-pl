{
  "manifest_version": 3,
  "name": "chrome-subtitle-translator-pl",
  "version": "0.1.0",
  "description": "Chrome extension for extracting video text and subtitles.",
  "permissions": ["activeTab", "tabs"],
  "host_permissions": ["https://www.youtube.com/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}